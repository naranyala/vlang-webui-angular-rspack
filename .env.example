# Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# Application Settings
# ==============================================================================

# Application name and version
APP_NAME=Desktop Dashboard
APP_VERSION=1.0.0

# Application environment (development, staging, production)
APP_ENV=development

# Debug mode (true/false)
APP_DEBUG=false

# ==============================================================================
# Server Configuration
# ==============================================================================

# Server host
SERVER_HOST=localhost

# Server port
SERVER_PORT=8080

# ==============================================================================
# Database Configuration
# ==============================================================================

# Database path (for JSON storage)
DB_PATH=duckdb_demo.json

# Enable demo data on startup (true/false)
DB_DEMO_MODE=true

# ==============================================================================
# Security Settings
# ==============================================================================

# Session timeout in seconds (default: 3600 = 1 hour)
SESSION_TIMEOUT=3600

# CSRF token timeout in seconds (default: 3600 = 1 hour)
CSRF_TIMEOUT=3600

# Rate limiting: requests per minute
RATE_LIMIT_PER_MINUTE=60

# Rate limiting: requests per hour
RATE_LIMIT_PER_HOUR=1000

# Rate limiting: burst limit (requests per second)
RATE_LIMIT_BURST=10

# Secret key for session/token generation (generate a random string)
# IMPORTANT: Change this in production!
APP_SECRET_KEY=change-me-in-production

# ==============================================================================
# Logging Configuration
# ==============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Log to console (true/false)
LOG_TO_CONSOLE=true

# Log to file (true/false)
LOG_TO_FILE=false

# Log file path
LOG_FILE_PATH=logs/app.log

# ==============================================================================
# Frontend Configuration
# ==============================================================================

# Frontend dist path
FRONTEND_DIST_PATH=frontend/dist/browser

# ==============================================================================
# API Configuration
# ==============================================================================

# Development API URL (for frontend)
DEV_API_URL=http://localhost:8080

# Production API URL (for frontend)
PROD_API_URL=http://localhost:8080

# ==============================================================================
# Cache Configuration
# ==============================================================================

# Cache default TTL in seconds (default: 3600 = 1 hour)
CACHE_DEFAULT_TTL=3600

# Enable cache (true/false)
CACHE_ENABLED=true
